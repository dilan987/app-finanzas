# Database
DATABASE_URL=postgresql://finanzas_user:finanzas_pass_dev@localhost:5432/finanzas_db?schema=public

# JWT Secrets (minimum 64 characters each — generate with: openssl rand -base64 64)
JWT_ACCESS_SECRET=your_access_token_secret_here_must_be_at_least_64_characters_long_change_me
JWT_REFRESH_SECRET=your_refresh_token_secret_here_must_be_at_least_64_characters_long_change_me

# Server
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# SMTP (for password recovery emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
SMTP_FROM=noreply@finanzas.app
